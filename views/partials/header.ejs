<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="theme-<%= themeMode || 'dark' %>">
  <header class="site-header">
    <div class="container nav-row">
      <a href="/" class="brand">JayB<span>Shop</span></a>
      <nav class="nav-links">
        <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Home</a>
        <a href="/shop" class="<%= currentPath === '/shop' ? 'active' : '' %>">Shop</a>
        <a href="/announcements" class="<%= currentPath === '/announcements' ? 'active' : '' %>">Announcements</a>
        <a href="/about" class="<%= currentPath === '/about' ? 'active' : '' %>">About</a>
        <a href="/contact" class="<%= currentPath === '/contact' ? 'active' : '' %>">Contact</a>
      </nav>
      <div class="nav-actions">
        <a href="/cart" class="cart-link">
          Cart <span class="cart-count"><%= cartCount %></span>
        </a>
        <% if (buyer) { %>
          <a href="/account/orders" class="btn btn-outline btn-sm">My Orders</a>
          <form action="/logout" method="POST" style="display:inline">
            <button class="btn btn-sm btn-wine" type="submit">Log Out</button>
          </form>
        <% } else { %>
          <a href="/login" class="btn btn-outline btn-sm">Log In</a>
          <a href="/signup" class="btn btn-primary btn-sm">Sign Up</a>
        <% } %>
      </div>
    </div>
  </header>
